<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="kite"
        Arguments=""
        InstallLocation="C:\Program Files\Kite\Kite">
    </Installer>
    <PackageInformation
        PackageName="io.kite.desktop"
        PackageDisplayName="Kite"
        PublisherName="CN=Kite"
        PublisherDisplayName="Kite"
        Version="0.1.0.0"
        PackageDescription="Modern Kubernetes Desktop Dashboard">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="io.kite.desktop"
                Description="Modern Kubernetes Desktop Dashboard"
                DisplayName="Kite"
                ExecutableName="kite"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Kite</DisplayName>
            <PublisherDisplayName>Kite</PublisherDisplayName>
            <Description>Modern Kubernetes Desktop Dashboard</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="app.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
